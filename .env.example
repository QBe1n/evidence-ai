# ── EvidenceAI Environment Configuration ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | production | test
SECRET_KEY=change-me-to-a-random-64-char-secret-key
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://evidence:evidence@localhost:5432/evidenceai
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CACHE_TTL_SECONDS=3600       # 1 hour default cache TTL

# ── LLM Providers ─────────────────────────────────────────────────────────────
# At least one LLM provider is required for triangulation and summarization.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini     # gpt-4o-mini (default) | gpt-4o | gpt-4-turbo

# Optional: Claude fallback
ANTHROPIC_API_KEY=           # sk-ant-...
ANTHROPIC_MODEL=claude-3-haiku-20240307

# ── NCBI (PubMed / ClinicalTrials) ───────────────────────────────────────────
# Without an API key: 3 requests/second
# With an API key: 10 requests/second
# Get yours at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=                # Recommended for production
NCBI_EMAIL=your-email@example.com  # Required by NCBI eUtils policy

# ── FDA Databases ─────────────────────────────────────────────────────────────
FDA_OPENFDA_API_KEY=         # Get at: https://open.fda.gov/apis/authentication/
                              # Free tier: 240 req/min; with key: 240,000 req/min

# ── AWS (optional: model storage, document storage) ───────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=evidenceai-documents
S3_MODELS_BUCKET=evidenceai-models

# ── Authentication ────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ── ML Model Configuration ───────────────────────────────────────────────────
PICOX_MODEL_PATH=models/picox-pubmedbert-large    # Local path or HF model ID
EVIDENCE_OUTCOMES_MODEL_PATH=models/evidence-outcomes-biomedbert
MEDREVIEW_MODEL_PATH=models/medreview-llama2-7b  # Fine-tuned summarization model
DEVICE=cpu                   # cpu | cuda | mps
MODEL_CACHE_DIR=./.model_cache

# ── Celery Worker ─────────────────────────────────────────────────────────────
CELERY_TASK_SOFT_TIME_LIMIT=1800   # 30 minutes
CELERY_TASK_TIME_LIMIT=3600        # 1 hour
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_MAX_TASKS_PER_CHILD=100

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_SYNTHETIC_AUGMENTATION=true
ENABLE_LLM_SUMMARIZATION=true
ENABLE_CONTINUOUS_MONITORING=false  # Requires beat scheduler
REQUIRE_HUMAN_REVIEW=false          # Flag all reviews for human verification

# ── Notifications (optional) ─────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL_FROM=noreply@evidenceai.com
